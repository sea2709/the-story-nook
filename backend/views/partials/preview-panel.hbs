<div class="pv-editor">
  <div class="pv-top">
    <!-- Spread view -->
    <div id="spread-area">
      {{> spread-editor book=book spread=(lookup book.pages spreadIdx) spreadIdx=spreadIdx}}
    </div>

    <!-- Feedback section -->
    <div class="fb-section">
      <div class="fb-hd">SPREAD FEEDBACK &amp; NOTES</div>
      <div id="fb-thread">
        {{> fb-thread feedback=(lookup (lookup book.pages spreadIdx) 'fb')}}
      </div>
      <form class="fb-row"
            hx-post="/admin/books/{{book.id}}/spread/{{spreadIdx}}/feedback"
            hx-target="#fb-thread"
            hx-swap="innerHTML"
            hx-on:htmx:after-request="this.reset();document.getElementById('fb-thread').scrollTop=9999">
        <input type="text" class="fb-inp" name="text"
               placeholder="e.g. The sky should be stormy…">
        <button type="submit" class="btn btn-gold btn-sm">Send</button>
      </form>
    </div>
  </div>

  <!-- Spread strip -->
  <div id="strip-area">
    {{> spread-strip book=book spreadIdx=spreadIdx}}
  </div>

  <!-- Operations toolbar -->
  <div class="op-tb">
    <span class="op-lbl">SPREAD OPS</span>
    <button class="op-btn"
            hx-get="/admin/books/{{book.id}}/spread/{{spreadIdx}}/split-form"
            hx-target="#modal-container"
            hx-swap="innerHTML">✂ Split</button>
    <button class="op-btn"
            hx-get="/admin/books/{{book.id}}/spread/{{spreadIdx}}/merge-form"
            hx-target="#modal-container"
            hx-swap="innerHTML">⊕ Merge w/ Prev</button>
    <button class="op-btn op-d"
            hx-delete="/admin/books/{{book.id}}/spread/{{spreadIdx}}"
            hx-target="#preview-area"
            hx-swap="innerHTML"
            hx-confirm="Delete this spread?">🗑 Delete</button>
    <div class="op-sep"></div>
    <button class="op-btn"
            hx-post="/admin/books/{{book.id}}/spread/{{spreadIdx}}/move"
            hx-vals='{"direction":"left"}'
            hx-target="#preview-area"
            hx-swap="innerHTML">← Move Left</button>
    <button class="op-btn"
            hx-post="/admin/books/{{book.id}}/spread/{{spreadIdx}}/move"
            hx-vals='{"direction":"right"}'
            hx-target="#preview-area"
            hx-swap="innerHTML">Move Right →</button>
    <div class="op-sep"></div>
    <button class="op-pub"
            hx-post="/admin/books/{{book.id}}/publish"
            hx-target="#preview-area"
            hx-swap="innerHTML">✦ Publish to Library</button>
  </div>
</div>

<script>
  window._pvState = { bookId: '{{book.id}}', spreadIdx: {{spreadIdx}} };
</script>
