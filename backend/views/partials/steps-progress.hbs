<div id="steps-container"
  {{#if polling}}
  hx-get="/admin/jobs/{{jobId}}/status"
  hx-trigger="every 600ms"
  hx-target="this"
  hx-swap="outerHTML"
  {{/if}}>
  <div class="bg-black/30 rounded p-[1.1rem_1.2rem] block mt-[.9rem]">
    <div class="font-cinzel text-[.68rem] tracking-widest text-accent-gold mb-[.7rem]">
      {{#if done}}Complete!{{else if error}}Error — check console{{else}}Processing…{{/if}}
    </div>
    {{#each job.steps}}
    <div class="flex items-center gap-2 py-1.25 border-b border-parchment/[.07] text-[.78rem] text-parchment/70 last:border-b-0">
      <span class="sic w-4 text-center shrink-0 {{stepClass this}}">{{stepIcon this}}</span>
      {{stepLabel @index}}
    </div>
    {{/each}}
  </div>
</div>
