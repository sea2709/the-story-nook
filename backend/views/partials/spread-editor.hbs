<div class="flex gap-[1.2rem] p-[1.2rem_1.6rem] flex-1 min-h-0" id="pv-spread">
  {{! Left page }}
  <div class="flex-1 bg-cream border-[1.5px] border-parchment-deep rounded-md flex flex-col overflow-hidden min-h-0 transition-colors duration-200">
    <div class="px-[.7rem] py-[.45rem] bg-parchment border-b border-parchment-deep flex items-center justify-between shrink-0">
      <span class="font-cinzel text-[.62rem] tracking-widest text-ink-muted">Page {{pageNum spreadIdx 'l'}}</span>
      <div class="flex gap-1">
        <button class="bg-transparent border border-parchment-deep text-ink-muted text-[.62rem] px-1.75 py-0.5 rounded-sm cursor-pointer font-lora transition-all duration-150 whitespace-nowrap hover:border-accent-gold hover:text-ink" data-edit-side="l">✎ Edit Text</button>
        <button class="bg-transparent border border-parchment-deep text-ink-muted text-[.62rem] px-1.75 py-0.5 rounded-sm cursor-pointer font-lora transition-all duration-150 whitespace-nowrap hover:border-accent-gold hover:text-ink"
                hx-get="/admin/books/{{book.id}}/spread/{{spreadIdx}}/regen-form?side=l"
                hx-target="#modal-container"
                hx-swap="innerHTML">↺ New Image</button>
      </div>
    </div>
    <div class="pv-illus flex-1 bg-page-bg flex items-center justify-center text-[3.5rem] relative overflow-hidden min-h-20">
      {{#if spread.leftImage}}<img src="{{spread.leftImage}}" alt="" class="w-full h-full object-cover absolute inset-0">{{else}}<span>{{spread.le}}</span>{{/if}}
      <div class="pv-ov absolute inset-0 bg-transparent flex items-center justify-center opacity-0 transition-all duration-200">
        <button class="bg-parchment/90 text-ink border-none font-lora text-[.7rem] px-2.75 py-1.25 rounded-sm cursor-pointer hover:bg-parchment"
                hx-get="/admin/books/{{book.id}}/spread/{{spreadIdx}}/regen-form?side=l"
                hx-target="#modal-container"
                hx-swap="innerHTML">↺ Regenerate</button>
      </div>
    </div>
    <div class="px-[.9rem] py-[.7rem] border-t border-parchment-deep bg-cream shrink-0">
      <div id="pvtd-l" class="font-lora text-[.85rem] leading-[1.65] text-ink min-h-9">
        {{#if spread.lt}}{{spread.lt}}{{else}}<span class="italic text-ink-muted">Empty</span>{{/if}}
      </div>
      <div id="pvte-l" class="hidden">
        <form hx-put="/admin/books/{{book.id}}/spread/{{spreadIdx}}/text"
              hx-target="#spread-area"
              hx-swap="innerHTML">
          <input type="hidden" name="side" value="l">
          <textarea class="w-full font-lora text-[.85rem] leading-[1.65] text-ink border border-accent-gold rounded-sm px-1.75 py-1.25 resize-none bg-cream outline-none min-h-13.5 block" id="pvta-l" name="text">{{spread.lt}}</textarea>
          <div class="flex gap-[.35rem] mt-[.35rem] justify-end">
            <button type="button" class="btn btn-ghost btn-sm" data-cancel-side="l">Cancel</button>
            <button type="submit" class="btn btn-gold btn-sm">Save</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  {{! Right page }}
  <div class="flex-1 bg-cream border-[1.5px] border-parchment-deep rounded-md flex flex-col overflow-hidden min-h-0 transition-colors duration-200">
    <div class="px-[.7rem] py-[.45rem] bg-parchment border-b border-parchment-deep flex items-center justify-between shrink-0">
      <span class="font-cinzel text-[.62rem] tracking-widest text-ink-muted">Page {{pageNum spreadIdx 'r'}}</span>
      <div class="flex gap-1">
        <button class="bg-transparent border border-parchment-deep text-ink-muted text-[.62rem] px-1.75 py-0.5 rounded-sm cursor-pointer font-lora transition-all duration-150 whitespace-nowrap hover:border-accent-gold hover:text-ink" data-edit-side="r">✎ Edit Text</button>
        <button class="bg-transparent border border-parchment-deep text-ink-muted text-[.62rem] px-1.75 py-0.5 rounded-sm cursor-pointer font-lora transition-all duration-150 whitespace-nowrap hover:border-accent-gold hover:text-ink"
                hx-get="/admin/books/{{book.id}}/spread/{{spreadIdx}}/regen-form?side=r"
                hx-target="#modal-container"
                hx-swap="innerHTML">↺ New Image</button>
      </div>
    </div>
    <div class="pv-illus flex-1 bg-page-bg flex items-center justify-center text-[3.5rem] relative overflow-hidden min-h-20">
      {{#if spread.rightImage}}<img src="{{spread.rightImage}}" alt="" class="w-full h-full object-cover absolute inset-0">{{else}}<span>{{spread.re}}</span>{{/if}}
      <div class="pv-ov absolute inset-0 bg-transparent flex items-center justify-center opacity-0 transition-all duration-200">
        <button class="bg-parchment/90 text-ink border-none font-lora text-[.7rem] px-2.75 py-1.25 rounded-sm cursor-pointer hover:bg-parchment"
                hx-get="/admin/books/{{book.id}}/spread/{{spreadIdx}}/regen-form?side=r"
                hx-target="#modal-container"
                hx-swap="innerHTML">↺ Regenerate</button>
      </div>
    </div>
    <div class="px-[.9rem] py-[.7rem] border-t border-parchment-deep bg-cream shrink-0">
      <div id="pvtd-r" class="font-lora text-[.85rem] leading-[1.65] text-ink min-h-9">
        {{#if spread.rt}}{{spread.rt}}{{else}}<span class="italic text-ink-muted">Empty</span>{{/if}}
      </div>
      <div id="pvte-r" class="hidden">
        <form hx-put="/admin/books/{{book.id}}/spread/{{spreadIdx}}/text"
              hx-target="#spread-area"
              hx-swap="innerHTML">
          <input type="hidden" name="side" value="r">
          <textarea class="w-full font-lora text-[.85rem] leading-[1.65] text-ink border border-accent-gold rounded-sm px-1.75 py-1.25 resize-none bg-cream outline-none min-h-13.5 block" id="pvta-r" name="text">{{spread.rt}}</textarea>
          <div class="flex gap-[.35rem] mt-[.35rem] justify-end">
            <button type="button" class="btn btn-ghost btn-sm" data-cancel-side="r">Cancel</button>
            <button type="submit" class="btn btn-gold btn-sm">Save</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
{{#if regenNote}}
<p class="italic text-[.78rem] text-ink-muted px-[1.6rem] py-[.4rem]">✦ {{regenNote}}</p>
{{/if}}
